{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "node_modules/@electric-sql/pglite/dist/**"
    }
  },
  "crons": [{ "path": "/api/cron/tick", "schedule": "0 8 * * *" }]
}
