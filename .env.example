# ---- Base ----
# PORT=3000
# JWT_SECRET=cambia-esto-por-una-cadena-larga-aleatoria
# APP_URL=https://tu-app.vercel.app          # usado en links de informes por email

# ---- Base de datos (Supabase / cualquier Postgres) ----
# Sin DATABASE_URL se usa un Postgres embebido (PGlite) en ./data (o /tmp en Vercel, efímero)
# DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ---- Email real (elige UNO; sin clave = modo simulado) ----
# Recomendado: Resend (resend.com)
# RESEND_API_KEY=re_xxxxxxxx
# MAIL_FROM=hola@tudominio.com               # dominio verificado en Resend
# Alternativa: SendGrid
# SENDGRID_API_KEY=SG.xxxxxxxx

# ---- SMS y WhatsApp reales: Twilio (twilio.com) ----
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_FROM_NUMBER=+34XXXXXXXXX
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Webhook de entrada (configúralo en el número de Twilio):
#   POST https://tu-app.vercel.app/api/webhooks/twilio/<locationId>

# ---- IA (Claude — console.anthropic.com) ----
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# ANTHROPIC_MODEL=claude-sonnet-5

# ---- Scheduler (esperas de workflows y recordatorios) ----
# En Vercel: el cron incluido corre cada hora; para más precisión apunta un
# pinger gratuito (cron-job.org) a GET /api/cron/tick cada 5 min.
# Cualquier tráfico también procesa jobs pendientes (lazy tick, 1/min).
# CRON_SECRET=otra-cadena-aleatoria
